{
    "name": "uoga-hunt-planner",
    "private": true,
    "version": "1.0.0",
    "description": "Local static server for the U.O.G.A. Hunt Planner",
    "scripts": {
        "start": "node server.js",
        "build:library-page": "node scripts/build-library-page-data.js",
        "build:viewer-pdfs": "node scripts/build-guidebook-viewer-pdfs.js",
        "build:public-contracts": "node scripts/build-public-data-contracts.js",
        "build:pages": "npm run build:library-page && npm run build:viewer-pdfs && npm run build:public-contracts && node scripts/build-pages-dist.js",
        "deploy:pages-dist": "node scripts/deploy-pages-dist.js",
        "export:data": "node export-data.js",
        "audit:2026": "node audit-2026-completeness.js",
        "apply:2026:supplements": "node apply-2026-supplements.js",
        "audit:2026:top500": "node audit-2026-completeness.js --top=500",
        "generate:page-data": "node scripts/generate-page-data.js",
        "canonical:rebuild": "node scripts/build-canonical-rebuild.js",
        "validate:canonical": "node scripts/validate-canonical.js",
        "validate:canonical:legacy": "node scripts/validate-canonical-json.js",
        "compare:runtime-contracts": "node scripts/compare-runtime-contracts.js",
        "promotion:safety": "node scripts/promotion-safety-check.js",
        "coverage:canonical": "node scripts/finalize-canonical-coverage.js",
        "sync:permits-2026": "node scripts/sync-permit-allocations-2026.js",
        "verify:permits-2026": "node scripts/verify-permit-allocations-2026.js",
        "reconcile:le-elk-2025": "node scripts/reconcile-le-elk-2025-permits.js",
        "reconcile:le-elk-2025:write": "node scripts/reconcile-le-elk-2025-permits.js --write",
        "integrity:hard-data": "node scripts/run-hard-data-integrity.js",
        "verify:join-integrity": "node scripts/verify-join-integrity.js",
        "sync:draw-reality-identity": "node scripts/normalize-draw-reality-identity-guardrail.js",
        "sync:draw-reality-runtime-trim": "node scripts/trim-and-normalize-draw-reality-runtime.js",
        "verify:boundaries-2026": "node scripts/verify-boundary-id-render-map-2026.js",
        "hunt-tables:2026:clean-xlsx": "py scripts/regenerate-hunt-tables-2026-clean-xlsx.py",
        "hunt-tables:2026:clean-xlsx:publish": "py scripts/regenerate-hunt-tables-2026-clean-xlsx.py --publish",
        "hunt-tables:2026:pdf": "py scripts/convert-hunt-tables-2026-xlxs-to-pdfs.py",
        "hunt-tables:2026:clean-all": "npm run hunt-tables:2026:clean-xlsx:publish && npm run hunt-tables:2026:pdf",
        "fetch:dwr-huntplanner:2026": "node scripts/fetch-dwr-huntplanner-hanumber-2026.js",
        "publish:hard-copy-tables": "node scripts/publish-formatted-hunt-tables.js",
        "test:canonical": "node tests/validate-canonical-json.test.js && node tests/canonical-rebuild.test.js",
        "test": "node tests/validate-canonical-json.test.js && node tests/canonical-rebuild.test.js && npm run verify:permits-2026",
        "build": "npm run build:pages"
    },
    "devDependencies": {
        "pdf-lib": "^1.17.1",
        "pdf-parse": "^1.1.4",
        "pdfkit": "^0.17.2",
        "playwright": "^1.60.0",
        "wrangler": "^4.88.0",
        "xlsx": "^0.18.5"
    },
    "main": "app.js",
    "directories": {
        "doc": "docs",
        "lib": "lib",
        "test": "tests"
    },
    "dependencies": {
        "adler-32": "^1.3.1",
        "base64-js": "^1.5.1",
        "blake3-wasm": "^2.1.5",
        "brotli": "^1.3.3",
        "browserify-zlib": "^0.2.0",
        "cfb": "^1.2.2",
        "clone": "^2.1.2",
        "codepage": "^1.15.0",
        "cookie": "^1.1.1",
        "crc-32": "^1.2.2",
        "crypto-js": "^4.2.0",
        "detect-libc": "^2.1.2",
        "dfa": "^1.2.0",
        "error-stack-parser-es": "^1.0.5",
        "esbuild": "^0.27.3",
        "fast-deep-equal": "^3.1.3",
        "fontkit": "^2.0.4",
        "frac": "^1.1.2",
        "jpeg-exif": "^1.1.4",
        "kleur": "^4.1.5",
        "linebreak": "^1.1.0",
        "miniflare": "^4.20260504.0",
        "node-ensure": "^0.0.0",
        "pako": "^1.0.11",
        "path-to-regexp": "^6.3.0",
        "pathe": "^2.0.3",
        "playwright-core": "^1.60.0",
        "png-js": "^1.1.0",
        "puppeteer": "^25.1.0",
        "restructure": "^3.0.2",
        "semver": "^7.7.4",
        "sharp": "^0.34.5",
        "ssf": "^0.11.2",
        "supports-color": "^10.2.2",
        "tiny-inflate": "^1.0.3",
        "tslib": "^2.8.1",
        "undici": "^7.24.8",
        "unenv": "^2.0.0-rc.24",
        "unicode-properties": "^1.4.1",
        "unicode-trie": "^2.0.0",
        "wmf": "^1.0.2",
        "word": "^0.3.0",
        "workerd": "^1.20260504.1",
        "ws": "^8.18.0",
        "youch": "^4.1.0-beta.10",
        "youch-core": "^0.3.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/UTAHOGA/HUNT-BUILDER.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/UTAHOGA/HUNT-BUILDER/issues"
    },
    "homepage": "https://github.com/UTAHOGA/HUNT-BUILDER#readme"
}
